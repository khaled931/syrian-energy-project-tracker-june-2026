# Data source
# Use json for the current static MVP.
# Use firebase after adding Firebase environment variables in Vercel.
VITE_DATA_SOURCE=json

# Admin access
# Comma-separated list of Google accounts allowed to manage the admin dashboard.
VITE_ALLOWED_USERS=

# Firebase public web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
